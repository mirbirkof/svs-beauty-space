# ═══════════════════════════════════════════════════════
#   SVS Beauty World — Shop API Environment Variables
#   Copy to .env and fill in values
# ═══════════════════════════════════════════════════════

# ── Database (обязательно) ─────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Server ─────────────────────────────────────────────
PORT=3011
# PUBLIC_BASE_URL=https://your-domain.com  # для ссылок в уведомлениях

# ── Auth (обязательно) ─────────────────────────────────
ADMIN_TOKEN=your-secret-admin-token-48-chars
JWT_SECRET=random-jwt-secret-for-staff-auth

# ── Telegram ───────────────────────────────────────────
TELEGRAM_NOTIFY_TOKEN=123456:ABC...     # бот для уведомлений клиентам
ADMIN_TG_CHAT=123456789                 # chat_id админа для алертов
TELEGRAM_BOT_TOKEN=from_BotFather       # бот для booking verification
TELEGRAM_BOT_USERNAME=Svs_beautybot     # username бота для deep-link
# JARVIS_BOT_TOKEN=                     # бот Jarvis (внутренний)

# ── BeautyPro CRM ─────────────────────────────────────
BEAUTYPRO_ID_KEY=application_id
BEAUTYPRO_SECRET_KEY=application_secret
# BEAUTYPRO_DATABASE_CODE=              # код базы (если multi-tenant)
# BEAUTYPRO_LOCATION_ID=                # ID филиала

# ── Платежи (опционально) ─────────────────────────────
# MONO_TOKEN=                           # Mono Acquiring API token

# ── Доставка (опционально) ────────────────────────────
# NOVAPOSHTA_API_KEY=                   # Нова Пошта API

# ── SMS (опционально) ─────────────────────────────────
# SMS_PROVIDER=turbosms                 # провайдер SMS для OTP
