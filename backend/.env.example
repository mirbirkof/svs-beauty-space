# ═══════════════════════════════════════════════════════════════════
#   SVS Beauty World — Shop API · Environment Manifest
#   Копия → .env (локально) или переменные в Render Dashboard (прод).
#
#   ⚠ ПЕРЕЕЗД НА ДРУГОЙ СЕРВЕР/БАЗУ:
#   Переменные с меткой [SECRET-CARRY] шифруют данные в БД. Если их
#   потерять или сгенерировать заново — зашифрованные данные (телефоны
#   клиентов, токены интеграций, лицензии) станут НЕЧИТАЕМЫМИ НАВСЕГДА.
#   Скопируй их 1:1 со старого сервера. Никогда не меняй на "новые".
#   Полный чек-лист переезда: см. MIGRATION.md
# ═══════════════════════════════════════════════════════════════════

# ── База данных (ОБЯЗАТЕЛЬНО) ──────────────────────────────────────
# Neon/Supabase/любой Postgres. Данные живут ЗДЕСЬ — переносятся с базой.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# DATABASE_URL_APP — роль app_tenant без BYPASSRLS (реально работает RLS).
# Если не задан — используется DATABASE_URL. На проде задавать ОБА.
# DATABASE_URL_APP=postgresql://app_tenant:pass@host/dbname?sslmode=require

# ── Хранилище файлов (фото клиентов, документы, AI-видео) ─────────
# Файлы НЕ в Postgres. Два режима:
#  1) Один сервер: UPLOADS_DIR → постоянный диск Render (переживает редеплой).
UPLOADS_DIR=/data/uploads
#  2) Несколько серверов (основной+резервный): общее облако (ниже BACKUP_S3_*).
#     Тогда файл при загрузке дублируется в облако, а любой сервер, у которого
#     его нет локально, тянет из облака. Диск становится просто кэшем.

# ── Общее облако файлов + офсайт-бэкапы БД (S3-совместимое) ────────
# ОДНИ И ТЕ ЖЕ ключи включают: (а) выгрузку бэкапов БД offsite,
# (б) общее хранилище файлов для мульти-сервера (failover).
# Работает с Cloudflare R2, Backblaze B2, DigitalOcean Spaces, AWS S3, MinIO.
# BACKUP_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# BACKUP_S3_REGION=auto
# BACKUP_S3_BUCKET=svs-crm
# BACKUP_S3_KEY=
# BACKUP_S3_SECRET=
# BACKUP_S3_PREFIX=svs-crm-backups/   # бэкапы; файлы кладутся в crm-files/

# ── Сервер ────────────────────────────────────────────────────────
PORT=3011
# SHOP_API_PORT=            # альт. порт (если задан — приоритет)
# PUBLIC_BASE_URL=https://svs-shop-api.onrender.com   # ссылки в уведомлениях
# PUBLIC_API_BASE_URL=      # база для API-ссылок
NODE_ENV=production

# ══ [SECRET-CARRY] КЛЮЧИ ШИФРОВАНИЯ — переносить 1:1, НЕ менять ══════
# PII_KEY — AES-256 телефонов/медданных клиентов (hex, 64 симв = 32 байта).
#   Потеря → телефоны клиентов не расшифровать, поиск по ним сломан.
#   Сгенерировать НОВЫЙ (только для первой установки):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_KEY=

# INTEGRATION_ENC_KEY — шифрует токены интеграций (Mono, SMS, соцсети) в БД.
#   Потеря → все сохранённые интеграции отвалятся, вводить заново.
INTEGRATION_ENC_KEY=

# LICENSE_KEY_SECRET — подпись/проверка лицензионных ключей SaaS.
#   Потеря → выданные лицензии станут невалидными.
LICENSE_KEY_SECRET=

# JWT_SECRET — подпись токенов входа сотрудников. Смена → всех разлогинит
#   (не потеря данных, но все переавторизуются). [SECRET-CARRY]
JWT_SECRET=
# Ротация ключей без разлогина — старый ключ ещё принимается:
# JWT_SECRET_PREVIOUS=
# JWT_KID=
# JWT_KID_PREVIOUS=

# ── Auth / доступ админки (ОБЯЗАТЕЛЬНО) ───────────────────────────
ADMIN_TOKEN=your-secret-admin-token-48-chars
# ADMIN_TOKEN_BOOTSTRAP_ONLY=1   # админ-токен только для первичной настройки
# ALLOW_DEV_LOGIN=               # НЕ включать на проде
# PASSWORD_MIN_LENGTH=8
ADMIN_ID=
# ADMIN_TG_CHAT=123456789        # chat_id админа для алертов
# OWNER_CHAT_ID=

# ── Telegram-боты ─────────────────────────────────────────────────
TELEGRAM_NOTIFY_TOKEN=123456:ABC...     # уведомления клиентам
TELEGRAM_BOT_TOKEN=from_BotFather       # booking verification
TELEGRAM_BOT_USERNAME=Svs_beautybot     # deep-link
# TELEGRAM_ADMIN_CHAT_ID=
# JARVIS_BOT_TOKEN=                      # внутренний бот Jarvis

# ── Мультитенант / домены ─────────────────────────────────────────
# TENANT_BASE_DOMAIN=
# DOMAIN_CNAME_TARGET=
# DOMAIN_SSL_PROVIDER=

# ── BeautyPro CRM (legacy, синк отключён BP_SYNC_DISABLED) ─────────
BP_SYNC_DISABLED=1
# BEAUTYPRO_ID_KEY=
# BEAUTYPRO_SECRET_KEY=
# BEAUTYPRO_DATABASE_CODE=
# BEAUTYPRO_LOCATION_ID=
# BEAUTYPRO_WEBHOOK_SECRET=

# ── Платежи (опционально) ─────────────────────────────────────────
