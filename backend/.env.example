# NOVAPOSHTA_SENDER_REF=
# NP_SENDER_CITY_REF=
# NP_SENDER_WAREHOUSE_REF=
# NP_SENDER_CONTACT_REF=
# NP_SENDER_PHONE=

# ── SMS / OTP (опционально) ───────────────────────────────────────
